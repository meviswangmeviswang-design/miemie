rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isAdmin() {
      return request.auth != null && 
             request.auth.token.email_verified == true && 
             request.auth.token.email == 'meviswangmeviswang@gmail.com'; // Using the user's email as admin
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Schema validation helpers
    function isValidSettings(data) {
      return data.keys().hasAll(['isCommissionsOpen', 'updatedAt']) &&
             data.isCommissionsOpen is bool &&
             data.updatedAt is number &&
             data.updatedAt == request.time.toMillis();
    }

    function isValidOrderPublicCreate(data) {
      return data.keys().hasAll(['title', 'orderType', 'status', 'createdAt', 'updatedAt']) &&
             data.size() == 5 &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.orderType is string && data.orderType.size() > 0 && data.orderType.size() <= 50 &&
             data.status == 0 &&
             data.createdAt == request.time.toMillis() &&
             data.updatedAt == request.time.toMillis();
    }

    function isValidOrderPublicUpdate(data, existingData) {
      return data.keys().hasAll(['title', 'orderType', 'status', 'createdAt', 'updatedAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.orderType is string && data.orderType.size() > 0 && data.orderType.size() <= 50 &&
             data.status is number && data.status >= 0 && data.status <= 6 &&
             data.createdAt == existingData.createdAt &&
             data.updatedAt == request.time.toMillis() &&
             (data.keys().hasAll(['officialOrderId']) ? (data.officialOrderId is string && data.officialOrderId.size() <= 128) : true);
    }
    function isValidOrderPrivate(data) {
      return data.keys().hasAll(['nickname', 'contact', 'details', 'referenceImageUrl']) &&
             data.size() == 4 &&
             data.nickname is string && data.nickname.size() <= 100 &&
             data.contact is string && data.contact.size() <= 100 &&
             data.details is string && data.details.size() <= 5000 &&
             data.referenceImageUrl is string && data.referenceImageUrl.size() <= 1000;
    }

    function isValidOrderAlias(data) {
      return data.keys().hasAll(['trackingId']) &&
             data.size() == 1 &&
             data.trackingId is string && data.trackingId.size() > 0 && data.trackingId.size() <= 128;
    }

    // Paths
    match /settings/{settingId} {
      allow get: if true;
      allow list: if isAdmin();
      allow write: if isAdmin() && isValidSettings(incoming());
    }

    match /orders/{orderId} {
      // Anyone can get by exact ID
      allow get: if isValidId(orderId);
      allow list: if isAdmin();
      
      // Creating requires atomicity with private data
      allow create: if isValidId(orderId) &&
                       isValidOrderPublicCreate(incoming()) &&
                       existsAfter(/databases/$(database)/documents/orders/$(orderId)/private/data);

      allow update: if isAdmin() &&
                       isValidOrderPublicUpdate(incoming(), existing()) &&
                       (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'officialOrderId', 'updatedAt']));
      allow delete: if isAdmin();
      
      match /private/data {
        allow get: if isAdmin();
        allow list: if isAdmin();
        allow create: if isValidId(orderId) && isValidOrderPrivate(incoming());
        allow update: if isAdmin() && isValidOrderPrivate(incoming());
        allow delete: if isAdmin();
      }
    }

    match /order_aliases/{aliasId} {
      allow get: if isValidId(aliasId);
      allow list: if isAdmin();
      allow create: if isAdmin() && isValidOrderAlias(incoming());
      allow update: if isAdmin() && isValidOrderAlias(incoming());
      allow delete: if isAdmin();
    }
  }
}
